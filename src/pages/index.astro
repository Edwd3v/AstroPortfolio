---
const defaultPath = "/es/";
---

<!doctype html>
<html lang="es">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width" />
    <meta name="robots" content="noindex" />
    <meta http-equiv="refresh" content={`0; url=${defaultPath}`} />
    <title>Edwd3v | Redirecting</title>
    <script is:inline>
      const language = navigator.language || navigator.userLanguage || "es";
      const target = language.toLowerCase().startsWith("en") ? "/en/" : "/es/";
      window.location.replace(target);
    </script>
  </head>
  <body>
    <main>
      <p>
        Redirigiendo al portafolio de Edwd3v.
        <a href="/es/">Español</a>
        ·
        <a href="/en/">English</a>
      </p>
    </main>
  </body>
</html>
