---
import { siteConfig, socialLinks, type SiteConfig } from "../../config/site";

type Props = {
  config?: SiteConfig;
  links?: typeof socialLinks;
};

const { config = siteConfig, links = socialLinks } = Astro.props as Props;
---

<section id="contact" class="mt-16 border-t border-text/10 pt-16 pb-20 md:mt-20 md:pt-20 md:pb-28">
  <div class="mx-auto max-w-3xl rounded-3xl border border-accent/20 bg-accent/8 p-6 md:p-8">
    <div class="space-y-4">
      <p class="font-heading text-xl tracking-[0.32em] uppercase text-accent/90">
        {config.contact.title}
      </p>
      <h2 class="font-heading text-2xl md:text-4xl leading-tight text-text">
        {config.contact.heading}
      </h2>
      <p class="max-w-2xl text-base md:text-lg leading-relaxed text-text/80">
        {config.contact.lead}
      </p>
      <p class="text-sm text-text/75">
        {config.availability}
      </p>
    </div>

    <div class="mt-8 flex flex-wrap gap-3">
      <a
        href={`mailto:${config.email}`}
        class="inline-flex items-center justify-center rounded-xl border border-accent/30 bg-bg px-5 py-3 text-sm font-medium text-text transition-transform duration-200 ease-out hover:-translate-y-0.5 focus:outline-none focus-visible:ring-2 focus-visible:ring-accent/70 focus-visible:ring-offset-2 focus-visible:ring-offset-bg"
      >
        {config.email}
      </a>

      {links.map((link) => (
        <a
          href={link.href}
          target="_blank"
          rel="noreferrer"
          class="inline-flex items-center justify-center rounded-xl border border-text/15 px-5 py-3 text-sm font-medium text-text/85 transition-transform duration-200 ease-out hover:-translate-y-0.5 hover:border-text/40 focus:outline-none focus-visible:ring-2 focus-visible:ring-accent/70 focus-visible:ring-offset-2 focus-visible:ring-offset-bg"
        >
          {link.label}
        </a>
      ))}
    </div>
  </div>
</section>
