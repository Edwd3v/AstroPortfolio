---
import { siteConfig, socialLinks, type SiteConfig } from "../../config/site";

type Props = {
  config?: SiteConfig;
  links?: typeof socialLinks;
};

const { config = siteConfig, links = socialLinks } = Astro.props as Props;
const contactIcons = {
  envelope: {
    viewBox: "0 0 24 24",
    path: "M20 4H4a2 2 0 0 0-2 2v12a2 2 0 0 0 2 2h16a2 2 0 0 0 2-2V6a2 2 0 0 0-2-2Zm0 4-8 5L4 8V6l8 5 8-5v2Z",
  },
  copy: {
    viewBox: "0 0 24 24",
    path: "M16 1H4a2 2 0 0 0-2 2v14h2V3h12V1Zm3 4H8a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h11a2 2 0 0 0 2-2V7a2 2 0 0 0-2-2Zm0 16H8V7h11v14Z",
  },
  github: {
    viewBox: "0 0 24 24",
    path: "M12 2C6.48 2 2 6.59 2 12.25c0 4.53 2.87 8.37 6.84 9.73.5.1.68-.22.68-.49 0-.24-.01-1.03-.01-1.88-2.78.62-3.37-1.21-3.37-1.21-.46-1.2-1.11-1.52-1.11-1.52-.91-.64.07-.63.07-.63 1 .07 1.53 1.05 1.53 1.05.9 1.58 2.35 1.12 2.92.86.09-.67.35-1.12.63-1.38-2.22-.26-4.56-1.14-4.56-5.08 0-1.12.39-2.03 1.03-2.75-.1-.26-.45-1.31.1-2.73 0 0 .84-.28 2.75 1.05A9.3 9.3 0 0 1 12 6.92c.85 0 1.7.12 2.5.37 1.9-1.33 2.74-1.05 2.74-1.05.56 1.42.21 2.47.1 2.73.64.72 1.03 1.63 1.03 2.75 0 3.95-2.35 4.82-4.58 5.08.36.32.68.94.68 1.9 0 1.37-.01 2.48-.01 2.82 0 .27.18.59.69.49A10.27 10.27 0 0 0 22 12.25C22 6.59 17.52 2 12 2Z",
  },
  linkedin: {
    viewBox: "0 0 24 24",
    path: "M6.94 8.5H3.56V20h3.38V8.5ZM5.25 3A2.02 2.02 0 1 0 5.3 7.03 2.02 2.02 0 0 0 5.25 3ZM20.44 12.64c0-3.03-1.61-4.44-3.77-4.44-1.74 0-2.52.97-2.95 1.65V8.5h-3.38c.04.9 0 11.5 0 11.5h3.38v-6.42c0-.34.02-.68.13-.92.27-.68.88-1.39 1.9-1.39 1.34 0 1.88 1.05 1.88 2.6V20H21c.04-6.22 0-7.36 0-7.36Z",
  },
} as const;
---

<section id="contact" class="mt-16 border-t border-text/10 pt-16 pb-20 md:mt-20 md:pt-20 md:pb-28">
  <div class="mx-auto max-w-3xl rounded-3xl border border-accent/20 bg-accent/8 p-6 md:p-8">
    <div class="space-y-4">
      <p class="font-heading text-2xl md:text-3xl tracking-[0.24em] uppercase text-accent/90">
        {config.contact.title}
      </p>
      <p class="max-w-2xl text-base md:text-lg leading-relaxed text-text/80">
        {config.contact.cta}
      </p>
    </div>

    <div class="mt-8 space-y-4">
      <div class="flex flex-wrap gap-3">
        <button
          type="button"
          data-copy-email-button
          data-copy-email-value={config.email}
          data-copy-email-success={config.contact.copiedEmailLabel}
          aria-describedby="contact-copy-status"
          aria-label={config.contact.copyEmailLabel}
          class="group relative inline-flex h-12 min-w-12 items-center gap-1.5 rounded-xl border border-accent/30 bg-bg pl-3.5 pr-2 text-text transition-all duration-200 ease-out hover:-translate-y-0.5 hover:border-accent/50 focus:outline-none focus-visible:ring-2 focus-visible:ring-accent/70 focus-visible:ring-offset-2 focus-visible:ring-offset-bg group-data-[copied]:border-accent/70"
        >
          <span class="relative inline-flex shrink-0">
            <svg aria-hidden="true" class="h-5 w-5" viewBox={contactIcons.envelope.viewBox} fill="currentColor">
              <path d={contactIcons.envelope.path}></path>
            </svg>
            <span
              data-copy-badge
              class="pointer-events-none absolute -bottom-0.5 -right-0.5 flex h-2.5 w-2.5 items-center justify-center rounded-full bg-accent text-[7px] font-bold leading-none text-bg transition-transform duration-200 ease-[cubic-bezier(0.34,1.3,0.64,1)] group-data-[copied]:scale-0 group-data-[copied]:rotate-45"
            >
              +
            </span>
          </span>
          <span
            data-copy-feedback
            class="max-w-0 overflow-hidden whitespace-nowrap transition-[max-width] duration-200 delay-100 ease-out group-data-[copied]:max-w-40"
          >
            <span class="block translate-x-1.5 text-xs font-medium text-accent opacity-0 transition-all duration-200 delay-150 ease-out group-data-[copied]:translate-x-0 group-data-[copied]:opacity-100">
              {config.contact.copiedEmailLabel}
            </span>
          </span>
        </button>

        {links.map((link) => (
          <a
            href={link.href}
            target="_blank"
            rel="noopener noreferrer"
            aria-label={link.label === "GitHub" ? config.contact.githubLabel : config.contact.linkedInLabel}
            class="inline-flex h-12 w-12 items-center justify-center rounded-xl border border-text/15 text-text/85 transition-transform duration-200 ease-out hover:-translate-y-0.5 hover:border-text/40 focus:outline-none focus-visible:ring-2 focus-visible:ring-accent/70 focus-visible:ring-offset-2 focus-visible:ring-offset-bg"
          >
            <svg
              aria-hidden="true"
              class={link.label === "GitHub" ? "h-6 w-6" : "h-5 w-5"}
              viewBox={contactIcons[link.label === "GitHub" ? "github" : "linkedin"].viewBox}
              fill="currentColor"
            >
              <path d={contactIcons[link.label === "GitHub" ? "github" : "linkedin"].path}></path>
            </svg>
            <span class="sr-only">{link.label}</span>
          </a>
        ))}
      </div>
      <p
        id="contact-copy-status"
        role="status"
        aria-live="polite"
        class="sr-only"
      ></p>
    </div>
  </div>
</section>
