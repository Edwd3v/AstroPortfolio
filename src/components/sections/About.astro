---
import { siteConfig } from "../../config/site";
---

<section id="about" class="pt-24 md:pt-32">
  <div class="mx-auto max-w-3xl space-y-8">
    <header class="space-y-3">
      <p class="font-heading text-sm tracking-[0.4em] uppercase text-accent/80">
        Sobre mí
      </p>
      <h2 class="font-heading text-2xl md:text-4xl leading-tight text-text">
        Desarrollo frontend con criterio de producto y una base técnica clara.
      </h2>
    </header>

    <p class="max-w-prose text-base md:text-lg leading-relaxed text-text/80">
      {siteConfig.about.intro}
    </p>

    <ul class="grid gap-4 md:grid-cols-3">
      {siteConfig.about.focus.map((item) => (
        <li class="rounded-2xl border border-text/10 bg-bg/30 p-5 text-sm leading-relaxed text-text/75">
          {item}
        </li>
      ))}
    </ul>
  </div>
</section>
