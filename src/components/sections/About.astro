---
import { siteConfig, type SiteConfig } from "../../config/site";

type Props = {
  config?: SiteConfig;
};

const { config = siteConfig } = Astro.props as Props;
---

<section id="about" class="mt-16 border-t border-text/10 pt-16 md:mt-20 md:pt-20">
  <div class="mx-auto max-w-3xl space-y-8">
    <header class="space-y-3">
      <p class="font-heading text-xl tracking-[0.32em] uppercase text-accent/90">
        {config.about.title}
      </p>
      <h2 class="font-heading text-2xl md:text-4xl leading-tight text-text">
        {config.about.heading}
      </h2>
    </header>

    <p class="max-w-prose text-base md:text-lg leading-relaxed text-text/80">
      {config.about.intro}
    </p>

    <ul class="grid gap-4 md:grid-cols-3">
      {config.about.focus.map((item) => (
        <li class="rounded-2xl border border-text/12 bg-bg/35 p-5 md:p-6 text-sm leading-relaxed text-text/75">
          {item}
        </li>
      ))}
    </ul>
  </div>
</section>
