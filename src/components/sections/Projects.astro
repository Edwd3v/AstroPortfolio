---
import ProjectCard from "../ui/ProjectCard.astro";
import { siteConfig, type SiteConfig } from "../../config/site";
import { localizedProjects, type ProjectLocale } from "../../data/projects";

type Props = {
  config?: SiteConfig;
  locale?: ProjectLocale;
};

const { config = siteConfig, locale = "es" } = Astro.props as Props;
const projects = localizedProjects[locale];
const hasProjects = projects.length > 0;
---

<section id="projects" class="border-t border-text/10 pt-16 md:pt-20">
  <div class="mx-auto max-w-6xl space-y-8">
    <header>
      <h2 class="font-heading text-2xl md:text-3xl tracking-[0.24em] uppercase text-accent/90">
        {config.projects.title}
      </h2>
    </header>

    {
      hasProjects ? (
        <ul class="space-y-4">
          {projects.map((project) => <ProjectCard {...project} locale={locale} />)}
        </ul>
      ) : (
        <div class="rounded-2xl border border-dashed border-text/15 bg-bg/30 p-6 md:p-7">
          <p class="font-heading text-xs tracking-[0.32em] uppercase text-accent/85">
            {config.projects.emptyStatus}
          </p>
          <p class="mt-3 max-w-prose text-sm md:text-base leading-relaxed text-text/75">
            {config.projects.emptyText}
          </p>
        </div>
      )
    }
  </div>
</section>
