---
import { defaultLocale, type Locale } from "../../config/site";

type Props = {
  class?: string;
  locale?: Locale;
};

const { class: className = "", locale = defaultLocale } = Astro.props as Props;
const isSpanish = locale === "es";
const targetHref = isSpanish ? "/en/" : "/es/";
const spanishState = isSpanish ? "is-active" : "is-idle";
const englishState = isSpanish ? "is-idle" : "is-active";
const spanishLabel = "ES";
const englishLabel = "EN";
---

<a
  href={targetHref}
  class={`language-switch ${isSpanish ? "language-switch--es" : "language-switch--en"} ${className}`}
  aria-label={isSpanish ? "Cambiar a inglés" : "Switch to Spanish"}
  data-language-switch
>
  <span class={`language-switch__option ${spanishState}`} aria-current={isSpanish ? "page" : undefined}>
    {spanishLabel}
  </span>
  <span class={`language-switch__option ${englishState}`} aria-current={!isSpanish ? "page" : undefined}>
    {englishLabel}
  </span>
</a>
