---
import type { Project } from "../../data/projects";

type Props = Project;

const {
  title,
  description,
  href,
  tech = [],
  status,
  kind,
  year,
  outcome,
  repository,
  links = [],
} = Astro.props as Props;
const cardClass =
  "group block rounded-2xl border border-text/12 bg-bg/35 p-6 md:p-7 transition-transform duration-200 ease-out hover:-translate-y-0.5 hover:border-accent/45 focus:outline-none focus-visible:ring-2 focus-visible:ring-accent/70 focus-visible:ring-offset-2 focus-visible:ring-offset-bg";
const projectLinks = [
  ...(repository ? [{ label: "Repository", href: repository }] : []),
  ...links,
];
const meta = [kind, year].filter(Boolean).join(" / ");
---

<li>
  <article class={cardClass}>
    <div class="space-y-5">
      <header class="space-y-3">
        <div class="flex flex-wrap items-start justify-between gap-3">
          {meta && (
            <p class="font-heading text-[11px] font-medium uppercase tracking-[0.24em] text-accent/85">
              {meta}
            </p>
          )}
          {status && (
            <p class="rounded-full border border-text/15 px-3 py-1 text-[10px] font-medium uppercase tracking-[0.22em] text-text/70">
              {status}
            </p>
          )}
        </div>

        <h3 class="font-heading text-lg md:text-xl leading-snug tracking-[0.16em] uppercase text-text/95">
          {title}
        </h3>
      </header>

      <p class="text-sm md:text-base leading-relaxed text-text/75">
        {description}
      </p>

      {outcome && (
        <p class="border-l border-accent/25 pl-4 text-sm leading-relaxed text-text/70">
          {outcome}
        </p>
      )}

      {tech.length > 0 && (
        <ul class="flex flex-wrap gap-2 pt-1" aria-label={`Tecnologías usadas en ${title}`}>
          {tech.map((item) => (
            <li class="rounded-full border border-text/10 px-3 py-1 text-[11px] text-text/75">
              {item}
            </li>
          ))}
        </ul>
      )}

      {(href || projectLinks.length > 0) && (
        <div class="flex flex-wrap gap-3 pt-2">
          {href && (
            <a
              href={href}
              target="_blank"
              rel="noreferrer"
              class="font-heading text-[11px] uppercase tracking-[0.24em] text-accent/85 transition-colors hover:text-accent focus:outline-none focus-visible:ring-2 focus-visible:ring-accent/70 focus-visible:ring-offset-2 focus-visible:ring-offset-bg rounded-md"
            >
              Demo
            </a>
          )}
          {projectLinks.map((link) => (
            <a
              href={link.href}
              target="_blank"
              rel="noreferrer"
              class="font-heading text-[11px] uppercase tracking-[0.24em] text-accent/85 transition-colors hover:text-accent focus:outline-none focus-visible:ring-2 focus-visible:ring-accent/70 focus-visible:ring-offset-2 focus-visible:ring-offset-bg rounded-md"
            >
              {link.label}
            </a>
          ))}
        </div>
      )}
    </div>
  </article>
</li>
