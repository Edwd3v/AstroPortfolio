---
import type { Project, ProjectLocale } from "../../data/projects";

type Props = Project & {
  locale?: ProjectLocale;
};

const {
  title,
  description,
  problem,
  solution,
  result,
  href,
  tech = [],
  status,
  repository,
  links = [],
  locale = "es",
} = Astro.props as Props;

const titleSlug = title
  .toLowerCase()
  .normalize("NFD")
  .replace(/[\u0300-\u036f]/g, "")
  .replace(/[^a-z0-9]+/g, "-")
  .replace(/(^-|-$)/g, "");
const headingId = `project-card-${titleSlug || "item"}`;

const cardClass =
  "project-card group rounded-2xl border border-text/12 bg-bg/35 transition duration-300 ease-out open:border-accent/35 open:bg-bg/45";
const projectLinks = [
  ...(repository ? [{ label: "Repository", href: repository }] : []),
  ...links,
];
const labels = {
  es: {
    problem: "Problema",
    solution: "Solución",
    result: "Resultado",
    stack: "Stack técnico",
    detailCue: "Ver detalles",
    preview: "Vista provisional",
    placeholder: `Vista provisional de ${title}`,
    tech: `Tecnologías usadas en ${title}`,
  },
  en: {
    problem: "Problem",
    solution: "Solution",
    result: "Result",
    stack: "Stack",
    detailCue: "View details",
    preview: "Temporary preview",
    placeholder: `Temporary preview of ${title}`,
    tech: `Technologies used in ${title}`,
  },
}[locale];

const detailItems = [
  { label: labels.problem, value: problem ?? description },
  { label: labels.solution, value: solution ?? description },
  { label: labels.result, value: result },
].filter((item): item is { label: string; value: string } => Boolean(item.value));
---

<li>
  <details class={cardClass}>
    <summary class="project-card__summary min-w-0 cursor-pointer list-none rounded-2xl p-4 focus:outline-none focus-visible:ring-2 focus-visible:ring-accent/70 focus-visible:ring-offset-2 focus-visible:ring-offset-bg md:p-5">
      <span class="flex flex-col gap-4">
        <span class="space-y-4">
          <span class="block space-y-2">
            <span
              id={headingId}
              role="heading"
              aria-level="3"
              class="block max-w-[26rem] font-heading text-base tracking-[0.14em] uppercase text-text/92"
            >
              {title}
            </span>
            {status && (
              <span class="inline-flex w-fit rounded-full border border-accent/20 bg-accent/8 px-3 py-1 text-[10px] font-medium uppercase tracking-[0.16em] text-accent/82">
                {status}
              </span>
            )}
          </span>

          <span class="block max-w-[34rem] text-sm leading-relaxed text-text/74">
            {description}
          </span>

        </span>

        <span>
          <span class="inline-flex w-fit items-center gap-2 rounded-xl border border-accent/28 bg-accent/12 px-3.5 py-2 font-heading text-[10px] uppercase tracking-[0.18em] text-accent/90 transition duration-200 ease-out group-hover:border-accent/40 group-hover:bg-accent/16 group-open:border-accent/45 group-open:bg-accent/18 group-open:text-accent focus-visible:border-accent/45">
            <span>{labels.detailCue}</span>
            <span class="inline-flex h-4 w-4 items-center justify-center rounded-full border border-current text-[11px] leading-none">
              +
            </span>
          </span>
        </span>
      </span>
    </summary>

    <div class="project-card__reveal min-w-0">
      <div class="project-card__reveal-inner grid gap-5 border-t border-text/10 px-6 pb-6 pt-5 md:px-6 md:py-6 lg:grid-cols-[minmax(15rem,18rem)_minmax(0,1fr)] lg:gap-6 lg:border-l lg:border-t-0">
        <div
          class="relative min-h-36 overflow-hidden rounded-xl border border-text/10 bg-text/[0.045] md:min-h-40 lg:min-h-full"
          role="img"
          aria-label={labels.placeholder}
        >
          <div class="absolute inset-0 bg-[radial-gradient(circle_at_24%_20%,rgba(108,196,199,0.18),transparent_34%),linear-gradient(135deg,rgba(205,204,204,0.11),rgba(205,204,204,0.025))]"></div>
          <div class="absolute inset-x-4 top-4 h-2 rounded-full bg-text/10"></div>
          <div class="absolute bottom-4 left-4 right-4 space-y-2">
            <span class="block h-2 w-2/3 rounded-full bg-text/14"></span>
            <span class="block h-2 w-1/2 rounded-full bg-accent/20"></span>
          </div>
          <p class="absolute right-4 top-4 font-heading text-[10px] uppercase tracking-[0.2em] text-text/45">
            {labels.preview}
          </p>
        </div>

        <div class="flex min-h-full flex-col gap-5 lg:justify-between">
          <div class="space-y-4">
            <div class="space-y-3">
              {detailItems.map((item) => (
                <div class="space-y-1.5">
                  <p class="font-heading text-[10px] uppercase tracking-[0.22em] text-accent/75">
                    {item.label}
                  </p>
                  <p class="text-sm leading-relaxed text-text/74">
                    {item.value}
                  </p>
                </div>
              ))}
            </div>

            {(href || projectLinks.length > 0) && (
              <div class="flex flex-wrap gap-3 pt-1">
                {href && (
                  <a
                    href={href}
                    target="_blank"
                    rel="noreferrer"
                    class="rounded-md font-heading text-[11px] uppercase tracking-[0.22em] text-accent/85 transition-colors hover:text-accent focus:outline-none focus-visible:ring-2 focus-visible:ring-accent/70 focus-visible:ring-offset-2 focus-visible:ring-offset-bg"
                  >
                    Demo
                  </a>
                )}
                {projectLinks.map((link) => (
                  <a
                    href={link.href}
                    target="_blank"
                    rel="noreferrer"
                    class="rounded-md font-heading text-[11px] uppercase tracking-[0.22em] text-accent/85 transition-colors hover:text-accent focus:outline-none focus-visible:ring-2 focus-visible:ring-accent/70 focus-visible:ring-offset-2 focus-visible:ring-offset-bg"
                  >
                    {link.label}
                  </a>
                ))}
              </div>
            )}
          </div>

          {tech.length > 0 && (
            <div class="space-y-2 border-t border-text/10 pt-4">
              <p class="font-heading text-[10px] uppercase tracking-[0.22em] text-text/48">
                {labels.stack}
              </p>
              <ul class="flex flex-wrap gap-1.5" aria-label={labels.tech}>
                {tech.map((item) => (
                  <li class="rounded-full border border-text/10 px-2.5 py-1 text-[10px] text-text/68">
                    {item}
                  </li>
                ))}
              </ul>
            </div>
          )}
        </div>
      </div>
    </div>
  </details>
</li>

<style>
  .project-card {
    --project-card-reveal-max-height: 44rem;
    display: block;
    overflow: hidden;
  }

  .project-card__summary::-webkit-details-marker {
    display: none;
  }

  .project-card__summary::marker {
    content: "";
  }

  .project-card__reveal {
    max-height: 0;
    overflow: hidden;
    opacity: 0;
    pointer-events: none;
    transform: translateY(-0.35rem);
    transition:
      max-height 360ms cubic-bezier(0.16, 1, 0.3, 1),
      opacity 220ms ease-out,
      transform 220ms ease-out;
  }

  .project-card__summary {
    transition: padding 260ms ease-out;
  }

  .project-card[open] .project-card__reveal {
    max-height: var(--project-card-reveal-max-height);
    opacity: 1;
    pointer-events: auto;
    transform: translateY(0);
  }

  @media (min-width: 768px) {
    .project-card {
      transition:
        transform 300ms ease-out,
        border-color 300ms ease-out,
        background-color 300ms ease-out;
    }

    .project-card__reveal {
      max-height: none;
      min-width: 0;
      opacity: 0;
      transform: translateY(-0.35rem);
    }

    .project-card__reveal-inner {
      background: rgb(205 204 204 / 0.025);
    }

    .project-card[open] .project-card__reveal {
      max-height: none;
      opacity: 1;
      pointer-events: auto;
      transform: translateY(0);
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .project-card,
    .project-card__summary,
    .project-card__reveal {
      transition: none;
    }

    .project-card__reveal {
      max-height: none;
      opacity: 1;
      transform: none;
    }
  }
</style>
