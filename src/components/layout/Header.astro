---
import LanguageSwitch from "../ui/LanguageSwitch.astro";
import { defaultLocale, localizedSite, type Locale } from "../../config/site";

type Props = {
  locale?: Locale;
};

const { locale = defaultLocale } = Astro.props as Props;
const { labels, navItems, siteConfig } = localizedSite[locale];
const name = siteConfig.name ?? "Tu Nombre";
---

<header class="sticky top-0 z-50 md:hidden">
  <div class="border-b border-text/10 bg-bg/70 backdrop-blur">
    <div class="mx-auto max-w-6xl px-6">
      <div class="flex h-16 items-center justify-between">
        <a
          href="#top"
          class="group inline-flex items-center gap-3 font-heading text-xs tracking-[0.35em] uppercase text-text/90
                 focus:outline-none focus-visible:ring-2 focus-visible:ring-accent/70 focus-visible:ring-offset-2 focus-visible:ring-offset-bg rounded-md"
          aria-label={labels.goHome}
        >
          <span
            aria-hidden="true"
            class="h-2 w-2 rounded-sm bg-accent/70 group-hover:bg-accent transition-colors"
          ></span>
          <span>{name.toUpperCase()}</span>
        </a>

        <nav aria-label={labels.mainNavigation} class="flex items-center gap-3">
          {navItems.map((item) => (
            <a
              href={item.href}
              data-label={item.label}
              data-nav-section={item.href.replace("#", "")}
              class="nav-signal font-heading text-[10px] tracking-[0.35em] uppercase text-text/75 transition-colors
                     hover:text-text focus:outline-none focus-visible:ring-2 focus-visible:ring-accent/70 focus-visible:ring-offset-2 focus-visible:ring-offset-bg rounded-md"
            >
              <span class="nav-signal__text">{item.label}</span>
            </a>
          ))}
        </nav>
      </div>
    </div>
  </div>
  <div class="border-b border-text/10 bg-bg/70 px-6 py-3 backdrop-blur">
    <LanguageSwitch locale={locale} />
  </div>
</header>
