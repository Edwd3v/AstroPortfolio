---
import LanguageSwitch from "../ui/LanguageSwitch.astro";
import { defaultLocale, localizedSite, type Locale } from "../../config/site";

type Props = {
  locale?: Locale;
};

const { locale = defaultLocale } = Astro.props as Props;
const { labels, navItems, siteConfig } = localizedSite[locale];
const name = siteConfig.name ?? "Tu Nombre";
const role = siteConfig.role ?? "Frontend Developer";
---

<aside class="hidden md:block md:sticky md:top-0 h-screen">
  <div class="h-full px-6 lg:px-10 pt-40 pb-10 flex flex-col justify-between">
    <div class="space-y-8">
      <div class="space-y-5">
        <p
          class="font-heading text-5xl lg:text-6xl tracking-[0.18em] uppercase text-text/95"
          data-logo-decode
          data-logo-final={name.toUpperCase()}
        >
          {name.toUpperCase()}
        </p>
        <p
          class="font-heading text-lg lg:text-xl tracking-[0.34em] uppercase text-accent/90"
        >
          {role}
        </p>
      </div>

      <nav aria-label={labels.sectionsNavigation} class="pt-6 space-y-4">
        {navItems.map((item) => (
          <a
            class="nav-signal block rounded-md font-heading text-base tracking-[0.28em] uppercase text-text/75 transition-colors hover:text-text focus:outline-none focus-visible:ring-2 focus-visible:ring-accent/70 focus-visible:ring-offset-2 focus-visible:ring-offset-bg"
            href={item.href}
            data-label={item.label}
            data-nav-section={item.href.replace("#", "")}
          >
            <span class="nav-signal__text">{item.label}</span>
          </a>
        ))}
      </nav>

    </div>

    <div class="space-y-4">
      <LanguageSwitch locale={locale} />
      <p class="text-sm text-text/60">
        © {new Date().getFullYear()}
        {name}
      </p>
    </div>
  </div>
</aside>
