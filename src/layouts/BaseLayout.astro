---
import { ClientRouter } from "astro:transitions";
import Header from "../components/layout/Header.astro";
import Sidebar from "../components/layout/Sidebar.astro";
import brandVertical from "../assets/brand/edwd3v-vertical.png";
import { defaultLocale, localizedSite, type Locale } from "../config/site";
import "../styles/global.css";

type Props = {
  locale?: Locale;
};

const { locale = defaultLocale } = Astro.props as Props;
const { labels, siteConfig } = localizedSite[locale];
const { description, locale: ogLocale, name, siteUrl, seo, title } = siteConfig;
const pageTitle = seo?.defaultTitle ?? title;
const baseUrl = siteUrl ? siteUrl.replace(/\/$/, "") : "";
const pathname = Astro.url.pathname === "/" ? "" : Astro.url.pathname;
const canonicalUrl = baseUrl ? `${baseUrl}${pathname}` : "";
const ogImage = String(seo?.ogImage ?? "");
const socialImageUrl =
  baseUrl && ogImage
    ? ogImage.startsWith("http")
      ? ogImage
      : `${baseUrl}${ogImage}`
    : "";
const alternateUrls = baseUrl
  ? {
      es: `${baseUrl}/es/`,
      en: `${baseUrl}/en/`,
      default: `${baseUrl}/es/`,
    }
  : null;
---

<!doctype html>
<html lang={siteConfig.htmlLang}>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width" />
    <meta name="description" content={description} />
    <meta name="generator" content={Astro.generator} />
    <meta name="theme-color" content="#333333" />
    <meta property="og:type" content="website" />
    <meta property="og:locale" content={ogLocale} />
    <meta property="og:site_name" content={name} />
    <meta property="og:title" content={pageTitle} />
    <meta property="og:description" content={description} />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={pageTitle} />
    <meta name="twitter:description" content={description} />
    {siteUrl && <link rel="canonical" href={canonicalUrl} />}
    {alternateUrls && <link rel="alternate" hreflang="es" href={alternateUrls.es} />}
    {alternateUrls && <link rel="alternate" hreflang="en" href={alternateUrls.en} />}
    {alternateUrls && <link rel="alternate" hreflang="x-default" href={alternateUrls.default} />}
    {siteUrl && <meta property="og:url" content={canonicalUrl} />}
    {socialImageUrl && <meta property="og:image" content={socialImageUrl} />}
    {socialImageUrl && <meta name="twitter:image" content={socialImageUrl} />}
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" href="/favicon.ico" />

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600&family=Oxanium:wght@500;600;700&display=swap"
      rel="stylesheet"
    />

    <title>{pageTitle}</title>
    <ClientRouter />
    <noscript>
      <style>
        .sidebar-footer-controls {
          opacity: 1;
          pointer-events: auto;
          transform: none;
        }
      </style>
    </noscript>
  </head>

  <body class="bg-bg text-text font-body antialiased">
    <div class="ambient-background" aria-hidden="true">
      <canvas class="neural-network" data-neural-network></canvas>
      <div class="cursor-spotlight" data-cursor-spotlight></div>
    </div>
    <img
      src={brandVertical.src}
      alt=""
      class="brand-watermark brand-watermark-primary"
      loading="eager"
      decoding="async"
      aria-hidden="true"
    />
    <img
      src={brandVertical.src}
      alt=""
      class="brand-watermark brand-watermark-reflection"
      loading="eager"
      decoding="async"
      aria-hidden="true"
    />

    <a
      href="#main"
      class="sr-only focus:not-sr-only focus:fixed focus:top-4 focus:left-4
             focus:rounded-lg focus:bg-bg focus:px-4 focus:py-2
             focus:ring-2 focus:ring-accent/60 z-50"
    >
      {labels.skipToContent}
    </a>

    <Header locale={locale} />

    <div class="mx-auto max-w-6xl">
      <div class="md:grid md:grid-cols-[320px_1fr] md:gap-16 lg:gap-32">
        <Sidebar locale={locale} />

        <main id="main" class="px-6 md:px-10 pt-12 md:pt-16">
          <slot />
        </main>
      </div>
    </div>

    <script>
      import { DEFAULT_DURATION, initLogoDecode } from "../scripts/logo-decode.js";
      import { initNeuralNetwork } from "../scripts/neural-network.js";
      import { initSectionNavigation } from "../scripts/section-nav.js";
      import { initSpotlight } from "../scripts/spotlight.js";

      const SIDEBAR_FOOTER_REVEAL_DELAY = DEFAULT_DURATION + 220;
      const pageState = window as Window & typeof globalThis & {
        __sidebarFooterRevealed?: boolean;
      };
      let cleanupPageEffects: Array<() => void> = [];
      let handledInitialPageLoad = false;

      function runCleanup() {
        for (const cleanup of cleanupPageEffects) {
          cleanup();
        }

        cleanupPageEffects = [];
      }

      function trackCleanup(cleanup: unknown) {
        if (typeof cleanup === "function") {
          cleanupPageEffects.push(cleanup as () => void);
        }
      }

      function initPageEffects() {
        runCleanup();
        document.body.dataset.sidebarFooterReady = pageState.__sidebarFooterRevealed
          ? "true"
          : "false";
        initLogoDecode();

        if (!pageState.__sidebarFooterRevealed) {
          const footerRevealTimer = window.setTimeout(() => {
            pageState.__sidebarFooterRevealed = true;
            document.body.dataset.sidebarFooterReady = "true";
          }, SIDEBAR_FOOTER_REVEAL_DELAY);

          trackCleanup(() => window.clearTimeout(footerRevealTimer));
        }

        trackCleanup(initSpotlight());
        trackCleanup(initNeuralNetwork(document.querySelector("[data-neural-network]")));
        trackCleanup(initSectionNavigation());
      }

      initPageEffects();

      document.addEventListener("astro:page-load", () => {
        if (!handledInitialPageLoad) {
          handledInitialPageLoad = true;
          return;
        }

        initPageEffects();
      });
    </script>
  </body>
</html>
